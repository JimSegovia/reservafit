# URL de la base de datos (Ejemplo para desarrollo local con Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reservafit?schema=public"

# URL base del cliente (Mobile/Web)
CLIENT_BASE_URL="http://localhost:8081"

# Puerto del servidor backend
PORT=3000

# Secreto JWT para firmar tokens de sesión
JWT_SECRET="reserva_fit_jwt_secret_dev_key_12345"

# Credenciales de pasarela de pagos (Mercado Pago)
MERCADO_PAGO_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxx-xxxxxxxx"

# API Key de Resend para el servicio de correo
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
